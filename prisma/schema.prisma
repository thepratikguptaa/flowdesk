// FlowDesk — Prisma schema
// Case management platform: users, departments, cases, workflow, timeline,
// comments, attachments, notifications, and audit logs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  CITIZEN // end user / student / employee — creates and tracks own cases
  STAFF // works assigned cases
  MANAGER // manages a department: assigns, prioritizes, escalates
  ADMIN // manages users, departments, config; sees everything
}

enum CaseStatus {
  SUBMITTED
  UNDER_REVIEW
  ASSIGNED
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
  REOPENED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  ASSIGNED
  STATUS_CHANGED
  COMMENT_ADDED
  RESOLVED
  REOPENED
  DUE_SOON
}

// Case-scoped, user-visible activity feed
enum CaseEventType {
  CREATED
  STATUS_CHANGED
  ASSIGNED
  PRIORITY_CHANGED
  COMMENT_ADDED
  ATTACHMENT_ADDED
  REOPENED
  CLOSED
  ESCALATED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CITIZEN)
  departmentId String?
  isActive     Boolean  @default(true)
  // Bumped on password reset / deactivation to invalidate existing JWT sessions.
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  reportedCases  Case[]         @relation("CaseReporter")
  assignedCases  Case[]         @relation("CaseAssignee")
  comments       Comment[]
  attachments    Attachment[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  caseEvents     CaseEvent[]

  @@index([departmentId])
  @@index([role])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
  cases Case[]
}

model Case {
  id          String     @id @default(cuid())
  caseNumber  Int        @unique @default(autoincrement()) // human-friendly ref: FD-000123
  title       String
  description String
  category    String
  priority    Priority   @default(MEDIUM)
  status      CaseStatus @default(SUBMITTED)
  dueDate     DateTime?

  reporterId   String
  assigneeId   String?
  departmentId String

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
  closedAt   DateTime?

  reporter   User        @relation("CaseReporter", fields: [reporterId], references: [id])
  assignee   User?       @relation("CaseAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  department Department  @relation(fields: [departmentId], references: [id])

  comments      Comment[]
  attachments   Attachment[]
  events        CaseEvent[]
  notifications Notification[]

  @@index([status])
  @@index([priority])
  @@index([departmentId])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([dueDate])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  caseId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case   Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([caseId])
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  mimeType     String
  size         Int // bytes
  caseId       String
  uploadedById String
  createdAt    DateTime @default(now())

  case       Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy User            @relation(fields: [uploadedById], references: [id])
  blob       AttachmentBlob?

  @@index([caseId])
}

// Binary payload kept in its own table so listing attachment metadata never
// loads file bytes. Deleted automatically with its parent Attachment.
model AttachmentBlob {
  attachmentId String     @id
  data         Bytes
  attachment   Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  caseId    String?
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  case Case? @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// User-facing timeline for a single case
model CaseEvent {
  id        String        @id @default(cuid())
  caseId    String
  actorId   String?
  type      CaseEventType
  message   String
  metadata  Json?
  createdAt DateTime      @default(now())

  case  Case  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([caseId])
}

// System-wide, immutable audit trail across all entities
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // e.g. "case.update", "user.create"
  entityType String // "Case", "User", "Department"
  entityId   String
  field      String? // which field changed, if applicable
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
